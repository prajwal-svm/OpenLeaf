# Opt-in secrets/flags for the e2e suite. Copy to e2e/.env (gitignored) and
# fill in real values; anything set in your shell takes precedence.

# GitHub personal access token (classic, `repo` scope). Enables the
# source-control stage/diff/commit test, which connects the app with this PAT.
E2E_GITHUB_TOKEN=

# Set to 1 to run the push-to-origin test. Configure the project's remote
# first, and delete the remote repo yourself afterwards.
E2E_GIT_PUSH=

# Set to 1 to skip the network-dependent font-download test.
E2E_SKIP_NETWORK=

# AI provider key for the real-conversation tests (28-ai-chat). The key is
# entered through the Settings UI into the hermetic test config only.
# E2E_AI_PROVIDER picks the provider card by visible name (default: Z.AI).
E2E_AI_TOKEN=
E2E_AI_PROVIDER=
