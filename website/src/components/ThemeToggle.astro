---
/*
 * Replaces Starlight's theme <select> (light / dark / auto) with a single
 * light/dark toggle button. On first load nothing is persisted, so Starlight's
 * head script resolves the system preference; the first click writes the chosen
 * theme to localStorage, and it sticks from then on.
 */
---

<button type="button" class="ol-theme-toggle" aria-label="Toggle light and dark theme" title="Toggle theme">
  <svg class="ol-t-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4" />
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" />
  </svg>
  <svg class="ol-t-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z" />
  </svg>
</button>

<script is:inline>
  (() => {
    const KEY = "starlight-theme";
    const effective = () => (document.documentElement.dataset.theme === "light" ? "light" : "dark");
    const apply = (theme) => {
      document.documentElement.dataset.theme = theme;
      try {
        window.StarlightThemeProvider?.updatePickers?.(theme);
      } catch {}
    };
    const syncIcons = () => {
      const t = effective();
      document.querySelectorAll(".ol-theme-toggle").forEach((b) => {
        b.dataset.state = t;
        b.setAttribute("aria-label", t === "dark" ? "Switch to light theme" : "Switch to dark theme");
      });
    };
    const onClick = () => {
      const next = effective() === "dark" ? "light" : "dark";
      try {
        localStorage.setItem(KEY, next);
      } catch {}
      apply(next);
      syncIcons();
    };
    const bind = () => {
      document.querySelectorAll(".ol-theme-toggle").forEach((b) => {
        if (b.dataset.bound) return;
        b.dataset.bound = "1";
        b.addEventListener("click", onClick);
      });
      syncIcons();
    };
    bind();
    document.addEventListener("astro:page-load", bind);
  })();
</script>

<style>
  .ol-theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    position: relative;
    width: 2rem;
    height: 2rem;
    border-radius: var(--ol-radius-md, 6px);
    border: 1px solid var(--sl-color-hairline-shade);
    background: transparent;
    color: var(--sl-color-white);
    cursor: pointer;
    transition: background-color 0.15s ease, border-color 0.15s ease;
  }
  .ol-theme-toggle:hover {
    background: color-mix(in srgb, var(--sl-color-white) 8%, transparent);
    border-color: color-mix(in srgb, var(--sl-color-white) 25%, transparent);
  }
  .ol-theme-toggle svg {
    position: absolute;
    width: 1.05rem;
    height: 1.05rem;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  /* Show the icon for the active theme; hide the other with a small rotate. */
  .ol-theme-toggle .ol-t-sun {
    opacity: 0;
    transform: rotate(-90deg) scale(0.5);
  }
  .ol-theme-toggle .ol-t-moon {
    opacity: 0;
    transform: rotate(90deg) scale(0.5);
  }
  .ol-theme-toggle[data-state="light"] .ol-t-sun {
    opacity: 1;
    transform: none;
  }
  .ol-theme-toggle[data-state="dark"] .ol-t-moon {
    opacity: 1;
    transform: none;
  }
</style>
