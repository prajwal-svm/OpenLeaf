---
/*
 * OpenLeaf landing sections, rendered below the Starlight splash hero. A product
 * showcase (the editor beside a live PDF), a feature grid, the three-step flow,
 * and a closing CTA. Pure Astro markup — no client JS — so it stays fast; the
 * screenshot goes through astro:assets for responsive, optimized delivery.
 */
import { Image } from "astro:assets";
import editor from "../assets/editor.jpg";

// Ordered for the bento grid: a 2x2 featured tile, two wide (2x1) tiles, and
// two small (1x1) tiles fill a 4-column grid exactly (see landing.css).
const features = [
  {
    size: "featured",
    title: "Local-first, fully offline",
    body: "Your files live on your disk as plain .tex. The bundled Tectonic engine compiles offline, with no account and no server between you and your work.",
    icon: '<rect x="2" y="4" width="20" height="13" rx="2"/><path d="M2 20h20"/><path d="M8 20v-3"/><path d="M16 20v-3"/>',
  },
  {
    size: "wide",
    title: "ATS & accessibility preflight",
    body: "One click checks a resume parses cleanly through applicant tracking systems, and a paper reads correctly for screen readers.",
    icon: '<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/>',
  },
  {
    size: "small",
    title: "Real Git, built in",
    body: "Every project is a real Git repo. Commit, branch, and push to GitHub in-app.",
    icon: '<line x1="6" y1="3" x2="6" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 0 1-9 9"/>',
  },
  {
    size: "small",
    title: "Live preview with SyncTeX",
    body: "A live pdf.js preview. Click either pane to jump to the matching spot.",
    icon: '<rect width="18" height="18" x="3" y="3" rx="2"/><path d="M12 3v18"/>',
  },
  {
    size: "wide",
    title: "IDE-grade code intelligence",
    body: "Go-to-definition, find references, project-wide rename, folding, and a live outline across every file. An editor that understands LaTeX.",
    icon: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
  },
  {
    size: "wide",
    title: "Bring your own AI",
    body: "An optional assistant that reads, edits, and recompiles your project. Use your own key, a local model with Ollama, or none at all.",
    icon: '<path d="M12 3l1.9 5.8a2 2 0 0 0 1.3 1.3L21 12l-5.8 1.9a2 2 0 0 0-1.3 1.3L12 21l-1.9-5.8a2 2 0 0 0-1.3-1.3L3 12l5.8-1.9a2 2 0 0 0 1.3-1.3z"/>',
  },
];

---

<div class="ol-landing">
  <!-- Product showcase -->
  <section class="ol-section ol-showcase">
    <div class="ol-glow" aria-hidden="true"></div>
    <div class="ol-window">
      <div class="ol-window-bar" aria-hidden="true">
        <span></span><span></span><span></span>
        <span class="ol-window-label">OpenLeaf | Resume</span>
      </div>
      <Image
        class="ol-shot"
        src={editor}
        alt="The OpenLeaf editor: LaTeX source with a resume compiling to a PDF live on the right, a file tree and outline on the left."
        widths={[640, 960, 1440, 2048]}
        sizes="(max-width: 1120px) 92vw, 1040px"
        loading="lazy"
      />
    </div>
    <p class="ol-showcase-caption">
      Source on the left, a live PDF on the right. Everything compiles on your machine.
    </p>
  </section>

  <!-- Features -->
  <section class="ol-section">
    <p class="ol-eyebrow">Why OpenLeaf</p>
    <h2 class="ol-h2">Everything you need to write, nothing that phones home</h2>
    <div class="ol-features-grid">
      {
        features.map((f) => (
          <article class={`ol-feature ol-feature--${f.size}`}>
            {f.size === "featured" && (
              <div class="ol-feature-visual" aria-hidden="true">
                <div class="ol-mini">
                  <div class="ol-mini-bar">
                    <i /><i /><i />
                    <span class="ol-mini-name">main.tex</span>
                  </div>
                  <div
                    class="ol-mini-body"
                    set:html={`<span><b class="k">\\documentclass</b>[11pt]<b class="k">{article}</b></span><span><b class="k">\\usepackage</b>{hyperref}</span><span><b class="k">\\begin</b>{document}</span><span class="ol-ind"><b class="k">\\section</b>{Summary}</span><span class="ol-ind m">Local-first LaTeX, on your own disk.</span><span><b class="k">\\end</b>{document}</span>`}
                  />
                </div>
              </div>
            )}
            <div class="ol-feature-head">
              <span class="ol-feature-icon" aria-hidden="true">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.6"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  set:html={f.icon}
                />
              </span>
              <h3 class="ol-feature-title">{f.title}</h3>
            </div>
            <p class="ol-feature-body">{f.body}</p>
          </article>
        ))
      }
    </div>
  </section>

  <!-- Closing CTA -->
  <section class="ol-section">
    <div class="ol-cta">
      <div class="ol-cta-inner">
        <span class="ol-cta-badge">FREE &amp; OPEN SOURCE</span>
        <h2 class="ol-cta-title">Write LaTeX without the cloud</h2>
        <p class="ol-cta-sub">
          Your files, tokens, and AI keys never leave your machine. Download a build for macOS, Windows, or Linux.
        </p>
        <div class="ol-cta-actions">
          <a class="ol-btn ol-btn-primary" href="https://github.com/prajwal-svm/OpenLeaf/releases/latest">
            Download OpenLeaf
          </a>
          <a class="ol-btn ol-btn-ghost" href="/OpenLeaf/getting-started/">Read the guide</a>
        </div>
      </div>
    </div>
  </section>
</div>
