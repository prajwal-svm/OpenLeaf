{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the OpenLeaf main, update, and preview windows.",
  "windows": ["main", "update", "preview"],
  "permissions": [
    "core:default",
    "core:webview:allow-create-webview-window",
    "core:window:allow-close",
    "core:window:allow-set-focus",
    "core:window:allow-center",
    "core:window:allow-start-dragging",
    "shell:allow-open",
    "os:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-ask",
    "dialog:allow-message",
    "updater:default",
    "process:allow-restart"
  ]
}
